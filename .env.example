# Waitlist confirmation emails (Resend — https://resend.com )
RESEND_API_KEY=re_xxxxxxxx

# “From” must be allowed by Resend (verified domain or onboarding@resend.dev for tests).
# Use any ONE of: WAITLIST_FROM_EMAIL, RESEND_FROM, RESEND_FROM_EMAIL
# In Vercel’s UI, paste the value once — do not wrap the whole line in extra "quotes"
# (the app strips common mistakes, but plain is best).
WAITLIST_FROM_EMAIL="First Sons <onboarding@resend.dev>"

# Production (Vercel, etc.): add BOTH variables in the host dashboard and redeploy.
# .env.local is NOT uploaded — it only works on your machine.
