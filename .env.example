# --- Resend (required for React Email sends) ---
RESEND_API_KEY=re_xxxxxxxx

# From address (verified domain in Resend). ASCII only.
# Examples: First Sons <hello@yourdomain.com>   OR   hello@yourdomain.com
WAITLIST_FROM_EMAIL=First Sons <hello@yourdomain.com>
# Aliases also supported:
# RESEND_FROM=
# RESEND_FROM_EMAIL=

# Discord + X (WaitlistConfirmationEmail, WelcomeEmail, Premium)
DISCORD_INVITE_URL=https://discord.gg/your-invite
# X_URL=https://x.com/Firstsons_Dao

# Optional: full URL to a PNG logo for all transactional emails (otherwise the gradient “F” + wordmark is used)
# EMAIL_LOGO_URL=https://yourdomain.com/logo-email.png
# Optional: separate invite for premium cohort (role-gated)
# PREMIUM_DISCORD_INVITE_URL=https://discord.gg/premium-invite

# Prisma MongoDB (optional — only if you use PremiumEnrollment model)
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/firstsons
